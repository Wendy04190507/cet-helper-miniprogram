.pomodoro-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg);
  padding-bottom: 120rpx;
}

.timer-ring {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.ring-bg {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  border: 8rpx solid var(--color-accent-soft);
}

.ring-canvas {
  position: absolute;
}

.timer-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  z-index: 1;
}

.timer-minutes,
.timer-seconds {
  font-size: 96rpx;
  font-weight: 200;
  color: var(--color-text-primary);
  font-family: "SF Mono", "Menlo", monospace;
  letter-spacing: -4rpx;
}

.timer-colon {
  font-size: 80rpx;
  font-weight: 200;
  color: var(--color-text-tertiary);
  margin: 0 4rpx;
}

.current-task {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.task-icon {
  font-size: 32rpx;
}

.task-name {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
}

.plant-area {
  text-align: center;
  margin-bottom: var(--space-lg);
}

.plant-emoji {
  font-size: 72rpx;
  display: block;
  margin-bottom: var(--space-xs);
  transition: transform 0.5s ease;
}

.plant-label {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
}

.swm-section {
  width: 100%;
  max-width: 500rpx;
  margin-bottom: var(--space-lg);
  padding: var(--space-md);
  background: var(--color-surface);
  border-radius: var(--radius-md);
}

.swm-title {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--space-sm);
}

.swm-peers {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.peer-item {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.peer-dot {
  color: var(--color-success);
  font-size: 16rpx;
}

.peer-label {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.timer-controls {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.ctrl-btn {
  width: 200rpx;
  background: var(--color-text-primary);
  color: #fff;
  border-radius: 48rpx;
  padding: var(--space-sm);
  font-size: var(--font-md);
  font-weight: 600;
}

.ctrl-btn.secondary {
  background: var(--color-accent-soft);
  color: var(--color-text-primary);
}

.ctrl-btn.minimal {
  background: transparent;
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-divider);
}

.duration-options {
  display: flex;
  gap: var(--space-md);
}

.dur-item {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
  padding: var(--space-xs) var(--space-md);
  border-radius: 24rpx;
  background: var(--color-accent-soft);
  transition: all 0.2s;
}

.dur-item.active {
  background: var(--color-text-primary);
  color: #fff;
}
