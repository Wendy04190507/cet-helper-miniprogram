<view class="settings-page">
  <!-- 用户画像卡片 -->
  <view class="profile-card">
    <view class="profile-emoji">📚</view>
    <view class="profile-info">
      <text class="profile-exam">{{examLabel}}</text>
      <text class="profile-date">考试日期：{{examDate}}</text>
      <text class="profile-time">每日 {{dailyTime}}</text>
    </view>
    <text class="edit-link" bind:tap="editProfile">调整</text>
  </view>

  <!-- 数据 -->
  <view class="settings-section">
    <text class="section-title">学习数据</text>
    <view class="setting-item" bind:tap="goWeeklyReport">
      <text>周度报告</text>
      <text class="arrow">→</text>
    </view>
    <view class="setting-item">
      <text>连续打卡</text>
      <text class="setting-value">{{streak}} 天</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="settings-section">
    <text class="section-title">设置</text>
    <view class="setting-item" bind:tap="goOnboarding">
      <text>重新评估</text>
      <text class="arrow">→</text>
    </view>
    <view class="setting-item">
      <text>字体大小</text>
      <picker mode="selector" range="{{fontSizes}}" bind:change="onFontChange">
        <text>{{fontSizes[fontSizeIndex]}}</text>
      </picker>
    </view>
  </view>

  <!-- 关于 -->
  <view class="settings-section">
    <text class="section-title">关于</text>
    <view class="setting-item">
      <text>版本</text>
      <text class="setting-value">v1.0.0</text>
    </view>
  </view>
</view>
