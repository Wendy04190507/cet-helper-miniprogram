.onboarding {
  padding: var(--space-lg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-indicator {
  display: flex;
  gap: 12rpx;
  margin-bottom: var(--space-xl);
}

.step-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-text-tertiary);
  transition: background 0.3s, transform 0.3s;
}

.step-dot.active {
  background: var(--color-text-primary);
  transform: scale(1.3);
}

.step-content {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: var(--space-xs);
  text-align: center;
}

.step-desc {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xl);
  text-align: center;
}

.option-grid {
  display: flex;
  gap: var(--space-md);
  width: 100%;
  justify-content: center;
  flex-wrap: wrap;
}

.option-card {
  width: 280rpx;
  padding: var(--space-lg);
  background: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  text-align: center;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}

.option-card.selected {
  border-color: var(--color-text-primary);
}

.option-emoji {
  font-size: 56rpx;
  display: block;
  margin-bottom: var(--space-sm);
}

.option-label {
  font-size: var(--font-lg);
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.option-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.date-picker-btn {
  padding: var(--space-md) var(--space-lg);
  background: var(--color-surface);
  border-radius: var(--radius-md);
  text-align: center;
  box-shadow: var(--shadow-card);
}

.date-text {
  font-size: var(--font-xl);
  font-weight: 600;
  display: block;
}

.date-hint {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.remaining-days {
  margin-top: var(--space-md);
  font-size: var(--font-md);
  color: var(--color-text-secondary);
}

.days-num {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.module-eval {
  width: 100%;
  max-width: 500rpx;
}

.eval-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.eval-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.eval-emoji {
  font-size: 36rpx;
}

.eval-label {
  font-size: var(--font-md);
  font-weight: 500;
}

.star-row {
  display: flex;
  gap: 4rpx;
}

.star {
  padding: 4rpx;
}

.star text {
  font-size: 40rpx;
  color: var(--color-text-tertiary);
  transition: color 0.15s;
}

.star.active text {
  color: #ff9f0a;
}

.radar-preview {
  margin-top: var(--space-lg);
}

.time-options {
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
  justify-content: center;
  width: 100%;
}

.finish-btn {
  margin-top: var(--space-xl);
  width: 100%;
  max-width: 400rpx;
  background: var(--color-text-primary);
  color: #fff;
  border-radius: 48rpx;
  padding: var(--space-md);
  font-size: var(--font-lg);
  font-weight: 600;
}

.next-btn {
  width: 100%;
  max-width: 400rpx;
  background: var(--color-text-primary);
  color: #fff;
  border-radius: 48rpx;
  padding: var(--space-md);
  font-size: var(--font-lg);
  font-weight: 600;
  margin-top: var(--space-xl);
}

.next-btn[disabled] {
  background: var(--color-text-tertiary);
}
