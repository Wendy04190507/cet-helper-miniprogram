.task-card {
  display: flex;
  align-items: center;
  padding: var(--space-md);
  background: var(--color-surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
}

.task-completed {
  opacity: 0.5;
}

.task-icon {
  font-size: 40rpx;
  margin-right: var(--space-md);
  flex-shrink: 0;
}

.task-body {
  flex: 1;
  min-width: 0;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.task-label {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

.task-duration {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  background: var(--color-accent-soft);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.task-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-source {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
  display: block;
}

.task-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--space-sm);
  flex-shrink: 0;
}

.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-text-tertiary);
}

.check-done {
  background: var(--color-success);
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-done text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}
