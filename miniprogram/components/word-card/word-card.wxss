.word-card-wrapper {
  position: relative;
  width: 100%;
  height: 480rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.word-card {
  width: 600rpx;
  height: 380rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
  transition: transform 0.15s ease-out, box-shadow 0.15s ease;
}

.word-card:active {
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.1);
}

.card-animating {
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
}

.card-left { transform: translateX(-120%) rotate(-15deg) !important; opacity: 0; }
.card-right { transform: translateX(120%) rotate(15deg) !important; opacity: 0; }
.card-down { transform: translateY(120%) !important; opacity: 0; }

.swipe-hint {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.left-hint {
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-danger);
}

.right-hint {
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-success);
}

.down-hint {
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  color: var(--color-warning);
}

.hint-active {
  opacity: 1;
}

.swipe-hint text {
  font-size: var(--font-md);
  font-weight: 600;
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: var(--space-lg);
  box-sizing: border-box;
}

.word-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
  letter-spacing: 2rpx;
}

.phonetic-text {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-md);
}

.meaning-text {
  font-size: var(--font-lg);
  color: var(--color-text-primary);
  font-weight: 500;
  text-align: center;
}

.example-box {
  margin-top: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  background: var(--color-accent-soft);
  border-radius: var(--radius-sm);
}

.example-text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-style: italic;
}

.example-source {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  display: block;
  margin-top: 4rpx;
}

.tap-hint {
  margin-top: var(--space-lg);
}

.tap-hint text {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
}

.gesture-guide {
  display: flex;
  justify-content: space-around;
  width: 600rpx;
  margin-top: var(--space-md);
  opacity: 0.6;
}

.guide-item text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.word-progress {
  margin-top: var(--space-sm);
}

.word-progress text {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
}
